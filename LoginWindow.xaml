<Window x:Class="ProjekatF1CMS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="F1 CMS"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Canvas Width="820" Height="580">

        <!-- Oblik -->
        <Path Fill="#1C1C1C"
              Stroke="#E10600"
              StrokeThickness="2">
            <Path.Data>
                <PathGeometry>
                    <PathFigure StartPoint="0,0" IsClosed="True">
                        <LineSegment Point="730,0"/>
                        <LineSegment Point="820,90"/>
                        <LineSegment Point="820,490"/>
                        <LineSegment Point="730,580"/>
                        <LineSegment Point="90,580"/>
                        <LineSegment Point="0,490"/>
                        <LineSegment Point="0,0"/>
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
        </Path>

        <!-- Crvena leva linija -->
        <Rectangle Canvas.Left="0"
                   Canvas.Top="0"
                   Width="6"
                   Height="495"
                   Fill="#E10600"/>

        <!-- Close dugme -->
        <Button Canvas.Left="680"
                Canvas.Top="15"
                Width="30"
                Height="30"
                Style="{StaticResource SecondaryButtonStyle}"
                Click="CloseButton_Click"
                ToolTip="Close">
            <fa5:SvgAwesome Icon="Solid_Times"
                            Height="12"
                            Foreground="#CCCCCC"/>
        </Button>

        <!-- Header -->
        <StackPanel Canvas.Left="25"
                    Canvas.Top="20"
                    Orientation="Horizontal">
            <fa5:SvgAwesome Icon="Solid_Flag"
                            Height="35"
                            Width="35"
                            Foreground="#E10600"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"/>
            <StackPanel VerticalAlignment="Center">
                <Label Content="FORMULA 1"
                       Foreground="White"
                       FontFamily="Agency FB"
                       FontSize="28"
                       FontWeight="Bold"
                       Padding="0"/>
                <Label Content="CONTENT MANAGEMENT SYSTEM"
                       Foreground="#E10600"
                       FontFamily="Agency FB"
                       FontSize="13"
                       Padding="0"
                       Margin="0,-8,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Separator ispod headera -->
        <Rectangle Canvas.Left="20"
                   Canvas.Top="85"
                   Width="770"
                   Height="2"
                   Fill="#E10600"/>

        <!-- Leva strana - branding -->
        <StackPanel Canvas.Left="40"
                    Canvas.Top="110"
                    Width="300"
                    VerticalAlignment="Center">

            <fa5:SvgAwesome Icon="Solid_Flag"
                            Height="90"
                            Width="90"
                            Foreground="#E10600"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,25"/>

            <Label Content="WELCOME BACK"
                   Foreground="White"
                   FontFamily="Agency FB"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Padding="0"/>

            <Label Content="In 2026 It's All To Drive For"
                   Foreground="#888888"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Padding="0"
                   Margin="0,5,0,30"/>

            <Rectangle Height="2"
                       Width="200"
                       Fill="#E10600"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <!-- Sezona info -->
            <Border Background="#2D2D2D"
                    CornerRadius="4"
                    Padding="15,10"
                    Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <fa5:SvgAwesome Icon="Solid_Trophy"
                                    Height="20"
                                    Width="20"
                                    Foreground="#FFD700"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"/>
                    <StackPanel>
                        <Label Content="2026 SEASON"
                               Foreground="White"
                               FontFamily="Agency FB"
                               FontSize="16"
                               Padding="0"/>
                        <Label Content="New regulations, new champions"
                               Foreground="#888888"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Padding="0"
                               Margin="0,-5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#2D2D2D"
                    CornerRadius="4"
                    Padding="15,10"
                    Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <fa5:SvgAwesome Icon="Solid_Users"
                                    Height="20"
                                    Width="20"
                                    Foreground="#E10600"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"/>
                    <StackPanel>
                        <Label Content="10 TEAMS"
                               Foreground="White"
                               FontFamily="Agency FB"
                               FontSize="16"
                               Padding="0"/>
                        <Label Content="Managing all competing teams"
                               Foreground="#888888"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Padding="0"
                               Margin="0,-5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#2D2D2D"
                    CornerRadius="4"
                    Padding="15,10">
                <StackPanel Orientation="Horizontal">
                    <fa5:SvgAwesome Icon="Solid_Flag"
                                    Height="20"
                                    Width="20"
                                    Foreground="#E10600"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"/>
                    <StackPanel>
                        <Label Content="24 RACES"
                               Foreground="White"
                               FontFamily="Agency FB"
                               FontSize="16"
                               Padding="0"/>
                        <Label Content="Full season calendar"
                               Foreground="#888888"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Padding="0"
                               Margin="0,-5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Vertikalni separator -->
        <Rectangle Canvas.Left="370"
                   Canvas.Top="100"
                   Width="1"
                   Height="460"
                   Fill="#444444"/>

        <!-- Desna strana - login forma -->
        <StackPanel Canvas.Left="400"
                    Canvas.Top="130"
                    Width="340">

            <Label Content="SIGN IN"
                   Foreground="White"
                   FontFamily="Agency FB"
                   FontSize="32"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

            <Label Content="Enter your credentials to continue"
                   Foreground="#888888"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Padding="0"
                   Margin="0,0,0,30"/>

            <Label Content="Username"
                   Foreground="#CCCCCC"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   Padding="0"
                   Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameTextBox"
                     Style="{StaticResource PrimaryTextBoxStyle}"
                     GotFocus="UsernameTextBox_GotFocus"
                     LostFocus="UsernameTextBox_LostFocus"/>
            <Label x:Name="UsernameErrorLabel"
                   Style="{StaticResource ValidationLabelStyle}"
                   Content=""/>

            <Label Content="Password"
                   Foreground="#CCCCCC"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   Padding="0"
                   Margin="0,15,0,5"/>
            <Grid>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource PrimaryPasswordBoxStyle}"
                             GotFocus="PasswordBox_GotFocus"
                             LostFocus="PasswordBox_LostFocus"/>
                <TextBlock x:Name="PasswordPlaceholder"
                           Text="Enter your password"
                           Foreground="#888888"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           IsHitTestVisible="False"/>
            </Grid>
            <Label x:Name="PasswordErrorLabel"
                   Style="{StaticResource ValidationLabelStyle}"
                   Content=""/>

            <Label x:Name="LoginErrorLabel"
                   Style="{StaticResource ValidationLabelStyle}"
                   Content=""
                   HorizontalAlignment="Center"
                   Margin="0,5,0,0"/>

            <Button x:Name="LoginButton"
                    Content="SIGN IN"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,25,0,0"
                    Click="LoginButton_Click"
                    ToolTip="Sign in to the system"/>

            <Button x:Name="ExitButton"
                    Content="EXIT"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,10,0,0"
                    Click="ExitButton_Click"
                    ToolTip="Close the application"/>

        </StackPanel>

    </Canvas>
</Window>