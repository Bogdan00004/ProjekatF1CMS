<Page x:Class="ProjekatF1CMS.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:fa5="http://schemas.fontawesome.com/icons/"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjekatF1CMS.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="950"
      Title="LoginPage"
      Background="{StaticResource PrimaryBackgroundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Leva strana - F1 branding -->
        <Grid Grid.Column="0" Background="{StaticResource SecondaryBackgroundColor}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Crvena linija akcenat -->
            <Rectangle Grid.Row="0" Grid.RowSpan="4"
                       Width="4"
                       HorizontalAlignment="Right"
                       Fill="{StaticResource AccentColor}"/>

            <fa5:SvgAwesome
                Grid.Row="1"
                Icon="Solid_Flag"
                Height="80"
                Width="80"
                Foreground="{StaticResource AccentColor}"
                HorizontalAlignment="Center"
                Margin="0,0,0,20"/>

            <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                <Label Content="FORMULA 1"
                       Style="{StaticResource TitleLabelStyle}"
                       FontSize="42"/>
                <Label Content="CONTENT MANAGEMENT SYSTEM"
                       Foreground="{StaticResource AccentColor}"
                       FontFamily="Agency FB"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Margin="0,-10,0,0"/>
                <Rectangle Height="3"
                           Width="200"
                           Fill="{StaticResource AccentColor}"
                           Margin="0,15,0,0"/>
                <Label Content="In 2026 It's All To Drive For"
                       Foreground="{StaticResource PlaceholderTextColor}"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Desna strana - Login forma -->
        <Grid Grid.Column="1" Margin="40,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">

                <Label Content="SIGN IN"
                       Style="{StaticResource TitleLabelStyle}"
                       FontSize="28"
                       Margin="0,0,0,30"/>
                          
                <!-- Username -->
                <Label Content="Username"
                       Style="{StaticResource PrimaryLabelStyle}"
                       Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox"
                       Style="{StaticResource PrimaryTextBoxStyle}"
                         GotFocus="UsernameTextBox_GotFocus"
                         LostFocus="UsernameTextBox_LostFocus"/>
                <Label x:Name="UsernameErrorLabel"
                       Style="{StaticResource ValidationLabelStyle}"
                       Content=""/>

                <!-- Password -->
                <Label Content="Password"
                    Style="{StaticResource PrimaryLabelStyle}" Margin="0,10,0,5"/>
                <Grid>
                    <PasswordBox x:Name="PasswordBox"
                    Style="{StaticResource PrimaryPasswordBoxStyle}" GotFocus="PasswordBox_GotFocus" LostFocus="PasswordBox_LostFocus"/>
                    <TextBlock x:Name="PasswordPlaceholder"
                        Text="Enter your password"
                        Foreground="{StaticResource PlaceholderTextColor}"
                        FontFamily="Segoe UI"
                        FontSize="13"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0"
                        IsHitTestVisible="False"/>
                </Grid>
                <Label x:Name="PasswordErrorLabel"
                    Style="{StaticResource ValidationLabelStyle}"
                    Content=""/>
                <!-- Login greška -->
                <Label x:Name="LoginErrorLabel"
                       Style="{StaticResource ValidationLabelStyle}"
                       Content=""
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>

                <!-- Dugmad -->
                <Button x:Name="LoginButton"
                        Content="SIGN IN"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,20,0,0"
                        Click="LoginButton_Click"
                        ToolTip="Sign in to the system"/>

                <Button x:Name="ExitButton"
                        Content="EXIT"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,10,0,0"
                        Click="ExitButton_Click"
                        ToolTip="Close the application"/>

            </StackPanel>
        </Grid>
    </Grid>
</Page>
