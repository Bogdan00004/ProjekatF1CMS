<Page x:Class="ProjekatF1CMS.Pages.TeamsTablePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:fa5="http://schemas.fontawesome.com/icons/"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjekatF1CMS.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="950"
      Title="TeamsTablePage"
       Background="{StaticResource PrimaryBackgroundColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <Grid Grid.Row="0" 
              Background="{StaticResource SecondaryBackgroundColor}"
              Height="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <fa5:SvgAwesome Grid.Column="0"
                    Icon="Solid_Flag"
                    Height="30"
                    Width="30"
                    Foreground="{StaticResource AccentColor}"
                    Margin="20,0,160,0"
                    VerticalAlignment="Center">
                <fa5:SvgAwesome.Style>
                    <Style TargetType="fa5:SvgAwesome">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#E10600"
                                             Direction="0"
                                             ShadowDepth="0"
                                             BlurRadius="25"
                                             Opacity="1" RenderingBias="Quality"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </fa5:SvgAwesome.Style>
            </fa5:SvgAwesome>

            <Label Grid.Column="1"
                   Content="F1 TEAMS"
                   Style="{StaticResource TitleLabelStyle}"
                   FontSize="26"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center">
                <Label.Effect>
                    <DropShadowEffect Color="#E10600"
                          Direction="0"
                          ShadowDepth="0"
                          BlurRadius="15"
                          Opacity="0.8"/>
                </Label.Effect>
            </Label>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Margin="0,0,20,0"
                        VerticalAlignment="Center">

                <!-- Logout dugme -->
                <Button x:Name="LogoutButton"
                        Width="100"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="LogoutButton_Click"
                        ToolTip="Sign out"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <fa5:SvgAwesome Icon="Solid_SignOutAlt"
                                        Height="13"
                                        Foreground="{StaticResource SecondaryTextColor}"
                                        Margin="0,0,6,0"/>
                        <TextBlock Text="LOGOUT"
                                   Foreground="{StaticResource SecondaryTextColor}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Exit dugme -->
                <Button x:Name="ExitButton"
                        Width="100"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="ExitButton_Click"
                        ToolTip="Close the application">
                    <StackPanel Orientation="Horizontal">
                        <fa5:SvgAwesome Icon="Solid_Times"
                                        Height="13"
                                        Foreground="{StaticResource SecondaryTextColor}"
                                        Margin="0,0,6,0"/>
                        <TextBlock Text="EXIT"
                                   Foreground="{StaticResource SecondaryTextColor}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Crvena linija ispod headera -->
        <Rectangle Grid.Row="0"
                   Height="3"
                   VerticalAlignment="Bottom"
                   Fill="{StaticResource AccentColor}"/>

        <!-- Toolbar - select all i add dugme -->
        <Grid Grid.Row="1" Margin="20,15,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="SelectAllCheckBox"
                      Grid.Column="0"
                      Content="Select All"
                      Style="{StaticResource PrimaryCheckBoxStyle}"
                      VerticalAlignment="Center"
                      Cursor="Hand"
                      Checked="SelectAllCheckBox_Checked"
                      Unchecked="SelectAllCheckBox_Unchecked"
                      ToolTip="Select all teams"/>

            <!-- Add dugme - samo za Admina -->
            <Button x:Name="AddTeamButton"
                    Grid.Column="2"
                    Width="130"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="AddTeamButton_Click"
                    ToolTip="Add a new F1 team">
                <StackPanel Orientation="Horizontal">
                    <fa5:SvgAwesome Icon="Solid_Plus"
                                    Height="13"
                                    Foreground="White"
                                    Margin="0,0,6,0"/>
                    <TextBlock Text="ADD TEAM"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- DataGrid -->
        <DataGrid x:Name="TeamsDataGrid"
                  Grid.Row="2"
                  Margin="20,0,20,0"
                  ItemsSource="{Binding Teams}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  Background="{StaticResource SecondaryBackgroundColor}"
                  Foreground="{StaticResource PrimaryTextColor}"
                  BorderBrush="{StaticResource BorderColor}"
                  BorderThickness="1"
                  RowBackground="{StaticResource SecondaryBackgroundColor}"
                  AlternatingRowBackground="#252525"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderColor}"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ColumnHeaderHeight="40"
                  RowHeight="50">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontFamily" Value="Agency FB"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="10,0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Background" Value="{StaticResource SecondaryBackgroundColor}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextColor}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#333333"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource SecondaryBackgroundColor}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <!-- CheckBox kolona -->
                <DataGridTemplateColumn Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Cursor="Hand"
                                      IsChecked="{Binding IsSelected, 
                                                  UpdateSourceTrigger=PropertyChanged,
                                                  Mode=TwoWay}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Hyperlink kolona - TeamName -->
                <DataGridTemplateColumn Header="Team Name" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock x:Name="TeamNameText"
                                    VerticalAlignment="Center"
                                    Margin="10,0"
                                    Cursor="Hand"
                                    Foreground="{StaticResource AccentColor}"
                                    MouseEnter="TeamNameText_MouseEnter"
                                    MouseLeave="TeamNameText_MouseLeave">
                                <Hyperlink x:Name="TeamHyperlink"
                                    Foreground="{StaticResource AccentColor}"
                                    TextDecorations="None"
                                    Click="TeamHyperlink_Click">
                                    <Run Text="{Binding TeamName}"/>
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Slika kolona -->
                <DataGridTemplateColumn Width="80">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Logo"
                                HorizontalAlignment="Center"
                                Foreground="White"
                                FontFamily="Agency FB"
                                FontSize="14"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Height="40"
                                   Width="60"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Source="{Binding LogoPath,
                             Converter={StaticResource RelativePathConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Datum kolona -->
                <DataGridTemplateColumn Header="Date Added" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DateAdded, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                       Foreground="{StaticResource SecondaryTextColor}"
                                       VerticalAlignment="Center"
                                       Margin="10,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="NoTeamsLabel"
           Grid.Row="2"
           Text="No teams added yet. Click ADD TEAM to get started."
           Foreground="{StaticResource PlaceholderTextColor}"
           FontFamily="Segoe UI"
           FontSize="16"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>

        <!-- Footer - Delete dugme -->
        <Grid Grid.Row="3" Margin="20,10">
            <Button x:Name="DeleteTeamButton"
                    Width="160"
                    HorizontalAlignment="Left"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="#8B0000"
                    Click="DeleteTeamButton_Click"
                    ToolTip="Delete selected teams">
                <StackPanel Orientation="Horizontal">
                    <fa5:SvgAwesome Icon="Solid_Trash"
                                    Height="13"
                                    Foreground="White"
                                    Margin="0,0,6,0"/>
                    <TextBlock Text="DELETE SELECTED"
                               Foreground="White"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>
